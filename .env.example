# TikTok credentials
TIKTOK_USERNAME=your_username_or_email
TIKTOK_PASSWORD=your_password

# Friend to DM (TikTok @username without the @)
TIKTOK_FRIEND_USERNAME=friend_username

# When to run daily (24h format, local timezone)
SCHEDULE_HOUR=18
SCHEDULE_MINUTE=0

# IANA timezone for the 6pm schedule (e.g. America/New_York, Asia/Jakarta)
TZ=America/New_York

# Browser: set to "true" to see the browser window (always "true" in GitHub Actions)
HEADLESS=false

# Optional: persist login session between runs
USER_DATA_DIR=./.browser-data

# --- GitHub Actions ---
# Add these as repository Secrets (Settings → Secrets and variables → Actions):
#   TIKTOK_USERNAME, TIKTOK_PASSWORD, TIKTOK_FRIEND_USERNAME
# Optional repository Variable:
#   TZ (e.g. America/New_York) — for logging only; cron time is set in .github/workflows/tiktok-daily.yml (UTC)
